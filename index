<body>
<div class="container">
  <div class="header">
    <h1>📝 ${Jn(e.title)}</h1>
    <div class="meta">
      ${e.className?`<div>القسم: ${Jn(e.className)}</div>`:""}
      ${e.subject?`<div>المادة: ${Jn(e.subject)}</div>`:""}
      ${e.teacherName?`<div>الأستاذ: ${Jn(e.teacherName)}</div>`:""}
      ${e.dueDateFormatted?`<div>تاريخ التسليم: ${Jn(e.dueDateFormatted)}</div>`:""}
      <div>النقطة القصوى: ${e.maxScore}/20</div>
    </div>
  </div>

  <div class="body">

    \x3C!-- Step 1: Login -->
    <div class="step active" id="step-login">
      <div id="login-error" class="alert alert-error" style="display:none"></div>
      <div class="field">
        <label for="massar">رقم المسار (رقم التلميذ)</label>
        <input type="text" id="massar" placeholder="N130032465" autocomplete="off" autocapitalize="none" inputmode="text" />
      </div>
      <div class="field">
        <label for="pin">الرمز السري (PIN)</label>
        <input type="password" id="pin" maxlength="4" placeholder="••••" inputmode="numeric" autocomplete="off" />
        <div class="score-hint">4 أرقام — أعطاك إياها أستاذك</div>
      </div>
      <button class="btn btn-primary" id="btn-verify" onclick="verifyStudent()">
        تحقق من الهوية
      </button>
    </div>

    \x3C!-- Step 2: Submit -->
    <div class="step" id="step-submit">
      <div id="student-name-box" class="student-name">
        <span>✓</span>
        <span id="student-name-text"></span>
      </div>
      <div id="submit-error" class="alert alert-error" style="display:none"></div>
      <div id="already-submitted" class="alert alert-info" style="display:none">
        لقد سبق لك تسليم هذا الواجب. يمكنك إعادة الإرسال للتحديث.
      </div>
      <div class="field">
        <label for="score">نقطتك (من ${e.maxScore})</label>
        <input type="number" id="score" min="0" max="${e.maxScore}" step="0.5" placeholder="0 – ${e.maxScore}" inputmode="decimal" />
      </div>
      <div class="divider"></div>
      <button class="btn btn-primary" id="btn-submit" onclick="submitHomework()">
        إرسال الواجب
      </button>
      <button class="btn btn-secondary" onclick="goBack()">
        → تسجيل الدخول من جديد
      </button>
    </div>

    \x3C!-- Step 3: Done -->
    <div class="step" id="step-done">
      <div class="alert alert-success" id="done-message">
        تم إرسال الواجب بنجاح ✓
      </div>
      <button class="btn btn-secondary" onclick="goBack()">
        إرسال إجابة أخرى
      </button>
    </div>

  </div>
  <div class="footer">
    دفتر الأستاذ · ${Jn(e.termLabel)} · رمز الواجب: ${Jn(e.token.slice(0,8))}…
  </div>
</div>

<script>
// ── Assignment metadata (baked in at export time) ──
const CONFIG = {
  token: ${JSON.stringify(e.token)},
  classId: ${JSON.stringify(e.classId)},
  termId: ${JSON.stringify(e.termId)},
  maxScore: ${e.maxScore},
  dueDate: ${JSON.stringify(e.dueDate)},
  scriptUrl: ${JSON.stringify(e.scriptUrl)},
}

let verifiedMassar = null
let verifiedName = null

function showStep(id) {
  document.querySelectorAll('.step').forEach(s => s.classList.remove('active'))
  document.getElementById(id).classList.add('active')
}

function setLoading(btnId, loading, label) {
  const btn = document.getElementById(btnId)
  btn.disabled = loading
  btn.innerHTML = loading ? '<span class="spinner"></span> جاري...' : label
}

function showError(id, msg) {
  const el = document.getElementById(id)
  el.textContent = msg
  el.style.display = 'block'
}

function hideError(id) {
  document.getElementById(id).style.display = 'none'
}

async function callScript(body) {
  const res = await fetch(CONFIG.scriptUrl, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
    redirect: 'follow',
  })
  if (!res.ok) throw new Error('فشل الاتصال بالخادم (HTTP ' + res.status + ')')
  const data = await res.json()
  return data
}

async function verifyStudent() {
  hideError('login-error')
  const massar = document.getElementById('massar').value.trim()
  const pin = document.getElementById('pin').value.trim()
  if (!massar) { showError('login-error', 'يرجى إدخال رقم المسار'); return }
  if (!pin || pin.length !== 4) { showError('login-error', 'يرجى إدخال الرمز السري المكوّن من 4 أرقام'); return }

  setLoading('btn-verify', true, 'تحقق من الهوية')
  try {
    const result = await callScript({
      action: 'verifyStudent',
      massarCode: massar,
      pin: pin,
      classId: CONFIG.classId,
      assignmentToken: CONFIG.token,
    })
    if (!result.ok) {
      showError('login-error', result.error ?? 'رقم المسار أو الرمز السري غير صحيح')
      return
    }
    verifiedMassar = massar
    verifiedName = result.studentName ?? massar
    document.getElementById('student-name-text').textContent = verifiedName
    if (result.alreadySubmitted) {
      document.getElementById('already-submitted').style.display = 'block'
    }
    showStep('step-submit')
  } catch (e) {
    showError('login-error', 'تعذر الاتصال. تحقق من اتصالك بالإنترنت وحاول مجدداً.')
  } finally {
    setLoading('btn-verify', false, 'تحقق من الهوية')
  }
}

async function submitHomework() {
  hideError('submit-error')
  const scoreStr = document.getElementById('score').value.trim()
  const score = scoreStr === '' ? null : parseFloat(scoreStr)
  if (score !== null && (isNaN(score) || score < 0 || score > CONFIG.maxScore)) {
    showError('submit-error', 'النقطة يجب أن تكون بين 0 و ' + CONFIG.maxScore)
    return
  }

  // Calculate late days
  const today = new Date().toISOString().split('T')[0]
  let lateDays = 0
  if (CONFIG.dueDate && today > CONFIG.dueDate) {
    const due = new Date(CONFIG.dueDate)
    const now = new Date(today)
    lateDays = Math.round((now - due) / 86400000)
  }

  setLoading('btn-submit', true, 'إرسال الواجب')
  try {
    const result = await callScript({
      action: 'submitHomework',
      assignmentToken: CONFIG.token,
      classId: CONFIG.classId,
      termId: CONFIG.termId,
      massarCode: verifiedMassar,
      pin: document.getElementById('pin').value.trim(),  // re-verified server-side
      score: score,
      lateDays: lateDays,
    })
    if (!result.ok) {
      showError('submit-error', result.error ?? 'فشل الإرسال — حاول مجدداً')
      return
    }
    const ts = result.submittedAt ? new Date(result.submittedAt).toLocaleString('ar-MA') : ''
    document.getElementById('done-message').textContent =
      'تم إرسال الواجب بنجاح ✓' + (ts ? '\\nالتوقيت: ' + ts : '')
    showStep('step-done')
  } catch (e) {
    showError('submit-error', 'تعذر الاتصال. تحقق من اتصالك وحاول مجدداً.')
  } finally {
    setLoading('btn-submit', false, 'إرسال الواجب')
  }
}

function goBack() {
  document.getElementById('pin').value = ''
  hideError('login-error')
  hideError('submit-error')
  document.getElementById('already-submitted').style.display = 'none'
  showStep('step-login')
}

// Allow Enter key to submit forms
document.getElementById('pin').addEventListener('keydown', e => {
